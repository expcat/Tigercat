{
  "compilerOptions": {
    "target": "ES2020",
    "useDefineForClassFields": true,
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "skipLibCheck": true,

    /* Bundler mode */
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx",

    /* Linting */
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "noFallthroughCasesInSwitch": true,
    "forceConsistentCasingInFileNames": true,

    /* Path mapping */
    "types": [],
    "paths": {
      "@/*": ["./src/*"],
      "@demo-shared/*": ["../shared/*"],
      "@demo-runtime/context": ["./src/playground/runtime-context.ts"],
      "@expcat/tigercat-core": ["../../../packages/core/src/index.ts"],
      "@expcat/tigercat-react": ["../../../packages/react/src/index.tsx"],
      "@expcat/tigercat-react/AnchorLink": ["../../../packages/react/src/components/Anchor"],
      "@expcat/tigercat-react/BreadcrumbItem": [
        "../../../packages/react/src/components/Breadcrumb"
      ],
      "@expcat/tigercat-react/DropdownItem": ["../../../packages/react/src/components/Dropdown"],
      "@expcat/tigercat-react/DropdownMenu": ["../../../packages/react/src/components/Dropdown"],
      "@expcat/tigercat-react/FloatButtonGroup": [
        "../../../packages/react/src/components/FloatButton"
      ],
      "@expcat/tigercat-react/InputGroupAddon": [
        "../../../packages/react/src/components/InputGroup"
      ],
      "@expcat/tigercat-react/MenuItem": ["../../../packages/react/src/components/Menu"],
      "@expcat/tigercat-react/MenuItemGroup": ["../../../packages/react/src/components/Menu"],
      "@expcat/tigercat-react/PrintPageBreak": [
        "../../../packages/react/src/components/PrintLayout"
      ],
      "@expcat/tigercat-react/StepsItem": ["../../../packages/react/src/components/Steps"],
      "@expcat/tigercat-react/SubMenu": ["../../../packages/react/src/components/Menu"],
      "@expcat/tigercat-react/TabPane": ["../../../packages/react/src/components/Tabs"],
      "@expcat/tigercat-react/*": ["../../../packages/react/src/components/*"]
    }
  },
  "include": ["src", "../shared"],
  "exclude": ["../shared/playground/vite-runtime-plugin.ts"],
  "references": [{ "path": "./tsconfig.node.json" }]
}
