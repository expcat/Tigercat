{
  "name": "tigercat",
  "version": "1.2.31",
  "private": true,
  "type": "module",
  "description": "A Tailwind CSS-based UI library supporting Vue 3 and React",
  "license": "MIT",
  "author": "Yizhe Wang",
  "repository": {
    "type": "git",
    "url": "https://github.com/expcat/Tigercat"
  },
  "keywords": [
    "ui",
    "component-library",
    "tailwindcss",
    "vue",
    "react",
    "typescript"
  ],
  "scripts": {
    "build": "pnpm -r --filter \"./packages/**\" build",
    "dev": "pnpm -r --filter \"./packages/**\" dev",
    "clean": "pnpm -r --filter \"./packages/**\" clean && node ./scripts/rimraf.mjs node_modules",
    "lint": "eslint packages --ext .ts,.tsx",
    "format": "prettier . --write",
    "format:check": "prettier . --check",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish",
    "release:next": "changeset version --snapshot next && pnpm build && changeset publish --tag next",
    "release:canary": "changeset version --snapshot canary && pnpm build && changeset publish --tag canary",
    "test": "vitest run",
    "test:core": "vitest run tests/core",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:a11y": "vitest run tests/vue tests/react tests/core/a11y-aa-regression.spec.tsx tests/core/a11y-interactive-regression.spec.tsx tests/core/composite-a11y-roles.spec.tsx",
    "test:vue": "vitest tests/vue",
    "test:react": "vitest tests/react",
    "test:validate": "node ./scripts/validate-tests.mjs",
    "size": "size-limit",
    "size:check": "size-limit --json",
    "quality:quick": "pnpm lint && pnpm types:check && pnpm api:validate && pnpm test:core",
    "quality:size": "pnpm size",
    "quality:examples": "pnpm example:build",
    "quality:ssr": "pnpm example:ssr:build",
    "quality:release": "pnpm release:check && pnpm quality:quick && pnpm quality:size && pnpm test:validate && pnpm quality:examples && pnpm quality:ssr",
    "release:check": "node ./scripts/check-release-readiness.mjs",
    "bench": "vitest bench",
    "api:validate": "node ./scripts/validate-api.mjs",
    "publish:check": "node ./scripts/publish-check.mjs",
    "sync:version": "node ./scripts/sync-version.mjs",
    "smoke:published": "node ./scripts/publish-check.mjs --published",
    "docs:api": "node ./scripts/generate-api-docs.mjs",
    "tokens:build": "node ./packages/core/scripts/generate-tokens.mjs",
    "types:check": "node ./scripts/check-public-types.mjs",
    "example:vue": "pnpm --filter @expcat/tigercat-example-vue3 dev",
    "example:react": "pnpm --filter @expcat/tigercat-example-react dev",
    "example:build": "pnpm --filter @expcat/tigercat-example-react build && pnpm --filter @expcat/tigercat-example-vue3 build",
    "example:ssr:nuxt": "pnpm --filter @expcat/tigercat-example-nuxt build",
    "example:ssr:next": "pnpm --filter @expcat/tigercat-example-nextjs build",
    "example:ssr:build": "pnpm example:ssr:nuxt && pnpm example:ssr:next",
    "example:all": "node ./scripts/run-examples.mjs",
    "dev:check": "node ./scripts/check-env.mjs",
    "setup": "node ./scripts/setup.mjs"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@testing-library/vue": "^8.1.0",
    "@types/node": "catalog:",
    "@types/react-dom": "catalog:",
    "@types/react-test-renderer": "^19.1.0",
    "@typescript-eslint/eslint-plugin": "^8.59.1",
    "@typescript-eslint/parser": "^8.59.1",
    "@vitejs/plugin-vue": "catalog:",
    "@vitest/coverage-v8": "^4.1.5",
    "@vitest/ui": "^4.1.5",
    "@vue/server-renderer": "catalog:",
    "axe-core": "catalog:",
    "eslint": "^10.2.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "happy-dom": "^20.9.0",
    "jest-axe": "^10.0.0",
    "jiti": "^2.6.1",
    "prettier": "^3.8.3",
    "react": "catalog:",
    "react-dom": "catalog:",
    "size-limit": "^12.1.0",
    "typescript": "catalog:",
    "vitest": "^4.1.5",
    "vue": "catalog:"
  },
  "packageManager": "pnpm@10.26.2",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=8.0.0"
  }
}
