{
  "name": "@expcat/tigercat-cli",
  "version": "2.0.0-preview.6",
  "type": "module",
  "description": "CLI tooling for Tigercat UI library — project scaffolding, component generation, and more",
  "license": "MIT",
  "author": "Yizhe Wang",
  "repository": {
    "type": "git",
    "url": "https://github.com/expcat/Tigercat",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/expcat/Tigercat#readme",
  "bugs": {
    "url": "https://github.com/expcat/Tigercat/issues"
  },
  "keywords": [
    "tigercat",
    "ui",
    "cli",
    "scaffolding",
    "code-generator"
  ],
  "bin": {
    "tigercat": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=22.12.0"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "clean": "node ../../scripts/rimraf.mjs dist"
  },
  "dependencies": {
    "commander": "^15.0.0",
    "picocolors": "^1.1.1",
    "prompts": "^2.4.2"
  },
  "devDependencies": {
    "@types/prompts": "^2.4.9",
    "tsup": "catalog:",
    "typescript": "catalog:"
  }
}
