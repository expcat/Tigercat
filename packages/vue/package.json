{
  "name": "@expcat/tigercat-vue",
  "version": "1.2.43",
  "description": "Vue 3 components for Tigercat UI library",
  "license": "MIT",
  "author": "Yizhe Wang",
  "repository": {
    "type": "git",
    "url": "https://github.com/expcat/Tigercat",
    "directory": "packages/vue"
  },
  "homepage": "https://expcat.github.io/Tigercat/vue/",
  "bugs": {
    "url": "https://github.com/expcat/Tigercat/issues"
  },
  "keywords": [
    "tigercat",
    "ui",
    "vue",
    "vue3",
    "components"
  ],
  "main": "./dist/index.mjs",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "sideEffects": [
    "./dist/chunk-*.mjs",
    "./dist/chunk-*.js",
    "./dist/components/*.mjs",
    "./dist/components/*.js"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.mjs"
    },
    "./*": {
      "types": "./dist/components/*.d.mts",
      "import": "./dist/components/*.mjs",
      "default": "./dist/components/*.mjs"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup --config tsup.config.ts",
    "dev": "tsup --config tsup.config.ts --watch",
    "clean": "node ../../scripts/rimraf.mjs dist"
  },
  "dependencies": {
    "@expcat/tigercat-core": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "@vitejs/plugin-vue": "catalog:",
    "tsup": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vue": "catalog:"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  }
}
